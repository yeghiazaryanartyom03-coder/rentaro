// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Car {
  id          String   @id @default(uuid())
  brand       String
  model       String
  year        Int
  priceAMD    Int
  fuel        String?
  transmission String?
  body        String?
  color       String
  engine      String?
  horsePower  Int?
  quantity    Int
  description String?
  seats       Int
  createdAt   DateTime @default(now())
  images      Image[]
  bookings    Booking[]
}

model Image {
  id    String @id @default(uuid())
  url   String
  carId String
  car   Car    @relation(fields: [carId], references: [id])
}

model Booking {
  id        String   @id @default(uuid())
  carId     String
  car       Car      @relation(fields: [carId], references: [id])
  firstName String
  lastName  String
  phone     String
  email     String
  startDate DateTime
  endDate   DateTime
  pickupLocation  String
  returnLocation  String
  status    String   @default("Pending")
  createdAt DateTime @default(now())
}